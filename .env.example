# =============================================================================
# Shhh — Environment Variables Reference (Production-First)
# =============================================================================
# This file is organized by WHERE each variable goes. Copy values from provider
# dashboards into the correct deployment target. Never commit real secrets.
#
# See docs/GET_ONLINE.md for step-by-step setup.
# =============================================================================


# =============================================================================
# SUPABASE (PostgreSQL + PostGIS)
# =============================================================================
# Where to get: Supabase Dashboard → Project Settings → Database
#
# You need TWO connection strings:
#
# 1) POOLER (for app runtime) — use for DATABASE_URL
#    Format: postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require
#    Port: 6543 (transaction mode, recommended for serverless)
#
# 2) DIRECT (for migrations only) — use for DATABASE_MIGRATION_URL
#    Format: postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres?sslmode=require
#    Port: 5432
#
# ⚠️ Do NOT mix them up. Pooler blocks DDL; migrations need direct.
# ⚠️ Replace [PASSWORD] with your actual DB password. URL-encode special chars.
#
# → Paste these into RENDER (see Render section below)
# -----------------------------------------------------------------------------
# DATABASE_URL=postgresql://postgres.xxx:YOUR_PASSWORD@aws-0-us-west-2.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require
# DATABASE_MIGRATION_URL=postgresql://postgres:YOUR_PASSWORD@db.xxx.supabase.co:5432/postgres?sslmode=require
# DATABASE_SSL=true
# DATABASE_POOL_SIZE=20
# DATABASE_SSL_REJECT_UNAUTHORIZED=false   # only if you get "self-signed certificate" errors


# =============================================================================
# UPSTASH (Redis)
# =============================================================================
# Where to get: Upstash Console → Create Database → Copy Redis URL
#
# Format: rediss://default:[PASSWORD]@[ENDPOINT].upstash.io:6379
#         ^^^^^^ double s = TLS required (Upstash always uses TLS)
#
# ⚠️ Use ONLY the URL. Do NOT paste redis-cli commands.
#    Wrong: redis-cli --tls -u redis://default:xxx@host:6379
#    Right: rediss://default:xxx@host.upstash.io:6379
#
# ⚠️ If your URL has redis:// and host is *.upstash.io, change to rediss://
#
# → Paste into RENDER as REDIS_URL
# -----------------------------------------------------------------------------
# REDIS_URL=rediss://default:YOUR_PASSWORD@your-endpoint.upstash.io:6379


# =============================================================================
# MONGODB ATLAS
# =============================================================================
# Where to get: Atlas → Database → Connect → Drivers → Node.js → Copy URI
#
# Format: mongodb+srv://[USER]:[PASSWORD]@[CLUSTER].mongodb.net/shhh_messages?retryWrites=true&w=majority&authSource=admin
#
# ⚠️ Add authSource=admin if missing (Atlas users are in admin DB)
# ⚠️ URL-encode password if it has special chars: ! → %21, @ → %40, # → %23
# ⚠️ Or use a password with only letters and numbers to avoid encoding
#
# ⚠️ Network Access: Add 0.0.0.0/0 (or Render IPs) so Render can connect
#
# → Paste into RENDER as MONGODB_URL
# -----------------------------------------------------------------------------
# MONGODB_URL=mongodb+srv://ShhhAdmin:YOUR_PASSWORD@cluster0.xxx.mongodb.net/shhh_messages?retryWrites=true&w=majority&authSource=admin


# =============================================================================
# RENDER (Backend Web Service)
# =============================================================================
# Where: Render Dashboard → Your Web Service → Environment
#
# Add ALL of these. Render has no local DB/Redis — everything comes from env.
#
# --- From Supabase (paste DATABASE_URL, DATABASE_MIGRATION_URL) ---
# DATABASE_URL=
# DATABASE_MIGRATION_URL=
# DATABASE_SSL=true
# DATABASE_POOL_SIZE=20
#
# --- From Upstash (paste REDIS_URL) ---
# REDIS_URL=
#
# --- From MongoDB Atlas (paste MONGODB_URL) ---
# MONGODB_URL=
#
# --- Generate with: openssl rand -hex 32 (use different values for each) ---
# JWT_SECRET=
# JWT_REFRESH_SECRET=
# PHONE_HASH_PEPPER=
#
# --- Required ---
# NODE_ENV=production
# CORS_ORIGINS=https://shhh.social,https://your-app.vercel.app
# PORT=3000
#
# --- Twilio (SMS, OTP, panic) — from Twilio Console ---
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=+1234567890
#
# --- OAuth (from provider consoles) ---
# GOOGLE_CLIENT_ID=
# APPLE_CLIENT_ID=app.shhh.mobile
# APPLE_TEAM_ID=
# APPLE_KEY_ID=
# SNAP_CLIENT_ID=
# SNAP_CLIENT_SECRET=
# SNAP_REDIRECT_URI=https://yourapp.com/oauth/snap/callback
#
# --- Stripe (from Stripe Dashboard) ---
# STRIPE_SECRET_KEY=sk_live_xxx
# STRIPE_WEBHOOK_SECRET=whsec_xxx
# APP_URL=shhh://
#
# --- Optional ---
# LOG_LEVEL=info
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_MAX_REQUESTS=2000
# AUTH_RATE_LIMIT_MAX=30
# DISCOVERY_RATE_LIMIT_PER_MIN=60
# METRICS_SECRET=       # When set, GET /metrics requires Authorization: Bearer <secret> or ?secret=<secret>
#
# --- OTP bypass (BLOCKED in production by validateProductionSecrets) ---
# OTP_DEV_BYPASS=true   # Dev/test only: returns OTP in API when Twilio not configured. NEVER set in production.


# =============================================================================
# VERCEL (Mobile Web / Frontend)
# =============================================================================
# Where: Vercel Dashboard → Project → Settings → Environment Variables
#
# ⚠️ Only EXPO_PUBLIC_* vars go here. They are exposed to the browser.
# ⚠️ NEVER put secrets (JWT, API keys, DB URLs) in Vercel.
#
# --- Required ---
# EXPO_PUBLIC_API_URL=https://your-backend.onrender.com
#    ↑ Your Render backend URL. No trailing slash.
#
# --- Optional (if using OAuth) ---
# EXPO_PUBLIC_GOOGLE_CLIENT_ID=
# EXPO_PUBLIC_SNAP_CLIENT_ID=


# =============================================================================
# ADMIN DASHBOARD (Vite)
# =============================================================================
# If deploying admin separately (e.g. Vercel, Netlify):
# Add VITE_API_URL at build time. Update admin-dashboard/src/api/client.ts to use it.
#
# VITE_API_URL=https://your-backend.onrender.com
# VITE_ALLOW_BYPASS=true   # Dev only: shows "Skip login" button. Never set in production builds.


# =============================================================================
# LOCAL DEVELOPMENT (.env at project root)
# =============================================================================
# Copy this section to .env for local dev. Uses docker-compose defaults.
# -----------------------------------------------------------------------------

NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

# Local docker-compose
DATABASE_URL=postgresql://shhh_dev:shhh_dev_password@localhost:5432/shhh
REDIS_URL=redis://localhost:6379
MONGODB_URL=mongodb://shhh_dev:shhh_dev_password@localhost:27017/shhh_messages?authSource=admin

# Dev secrets (never use in production)
JWT_SECRET=dev-jwt-secret
JWT_REFRESH_SECRET=dev-refresh-secret
PHONE_HASH_PEPPER=shhh-dev-pepper-change-in-production

# CORS for local
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8081,http://127.0.0.1:3000,http://127.0.0.1:5173

# Optional: point mobile at local backend
# EXPO_PUBLIC_API_URL=http://localhost:3000
