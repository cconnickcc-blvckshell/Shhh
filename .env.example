# Database
DATABASE_URL=postgresql://shhh_dev:shhh_dev_password@localhost:5432/shhh
REDIS_URL=redis://localhost:6379
MONGODB_URL=mongodb://shhh_dev:shhh_dev_password@localhost:27017/shhh_messages?authSource=admin

# Auth
JWT_SECRET=change-me-to-a-secure-random-string
JWT_REFRESH_SECRET=change-me-to-another-secure-random-string
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Server
PORT=3000
NODE_ENV=development
LOG_LEVEL=debug

# CORS (required in production). Comma-separated origins, e.g. https://app.example.com,https://admin.example.com
# CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Phone hash pepper (HMAC secret — generate with: openssl rand -hex 32)
PHONE_HASH_PEPPER=generate-a-secure-random-string-here

# Stripe
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret

# Twilio (required for production SMS verification)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Geo
DEFAULT_LOCATION_FUZZ_METERS=300
MAX_DISCOVERY_RADIUS_KM=100

# Mobile / Web (Expo). When set, web and native use this API base URL (e.g. https://api.yourdomain.com).
# If unset, app uses localhost / 10.0.2.2 for development.
# EXPO_PUBLIC_API_URL=https://api.yourdomain.com
