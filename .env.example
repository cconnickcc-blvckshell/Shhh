# =============================================================================
# Shhh — Environment Variables Reference
# =============================================================================
# Copy to .env and fill in values. Backend reads from project root .env.
# Mobile/Expo: Use app.config.js or .env with EXPO_PUBLIC_* for client-side.
#
# Target stack: Supabase (Postgres) + Redis + MongoDB
# See docs/SUPABASE_REDIS_MONGO_SETUP.md for setup guide.
# =============================================================================

# -----------------------------------------------------------------------------
# Database — Supabase (PostgreSQL + PostGIS)
# -----------------------------------------------------------------------------
# Local dev (docker-compose):
#   DATABASE_URL=postgresql://shhh_dev:shhh_dev_password@localhost:5432/shhh
#
# Supabase: Use connection string from Dashboard → Settings → Database.
#   Direct: postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres
#   Pooler (recommended): postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true
#   Add ?sslmode=require if not included.
DATABASE_URL=postgresql://shhh_dev:shhh_dev_password@localhost:5432/shhh

# Enable SSL for Supabase/cloud Postgres (set to true in production)
# DATABASE_SSL=true

# Connection pool size (default 20; increase for high concurrency)
# DATABASE_POOL_SIZE=50

# -----------------------------------------------------------------------------
# Redis (Upstash, Redis Cloud, or self-hosted)
# -----------------------------------------------------------------------------
# Local dev: redis://localhost:6379
# Upstash: redis://default:[PASSWORD]@[ENDPOINT].upstash.io:6379
# Redis Cloud: redis://default:[PASSWORD]@[HOST]:[PORT]
REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# MongoDB (Atlas or self-hosted)
# -----------------------------------------------------------------------------
# Local dev: mongodb://shhh_dev:shhh_dev_password@localhost:27017/shhh_messages?authSource=admin
# Atlas: mongodb+srv://[USER]:[PASSWORD]@[CLUSTER].mongodb.net/shhh_messages?retryWrites=true&w=majority
MONGODB_URL=mongodb://shhh_dev:shhh_dev_password@localhost:27017/shhh_messages?authSource=admin

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
PORT=3000
NODE_ENV=development
LOG_LEVEL=debug

# -----------------------------------------------------------------------------
# Auth — JWT (required in production; startup validates)
# -----------------------------------------------------------------------------
# Generate with: openssl rand -hex 32
JWT_SECRET=change-me-to-a-secure-random-string
JWT_REFRESH_SECRET=change-me-to-another-secure-random-string
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# -----------------------------------------------------------------------------
# Auth — Phone hash (required in production; startup validates)
# -----------------------------------------------------------------------------
# HMAC pepper for phone hashing. Generate with: openssl rand -hex 32
PHONE_HASH_PEPPER=generate-a-secure-random-string-here

# -----------------------------------------------------------------------------
# Auth — OTP / SMS (Twilio; required for production SMS)
# -----------------------------------------------------------------------------
# In dev, OTP returns devCode when Twilio not configured.
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# -----------------------------------------------------------------------------
# Auth — OAuth (Apple, Google, Snapchat)
# -----------------------------------------------------------------------------
# Apple: Services ID from Apple Developer (e.g. app.shhh.mobile)
APPLE_CLIENT_ID=app.shhh.mobile

# Google: OAuth 2.0 client ID from Google Cloud Console
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Snapchat: From Snap Kit / Snap for Developers
SNAP_CLIENT_ID=your-snap-client-id
SNAP_CLIENT_SECRET=your-snap-client-secret
# Must match redirect URI registered in Snap Developer Portal
SNAP_REDIRECT_URI=https://yourapp.com/oauth/snap/callback

# -----------------------------------------------------------------------------
# Security — CORS (required in production; startup validates)
# -----------------------------------------------------------------------------
# Comma-separated allowed origins. No trailing slashes.
# CORS_ORIGINS=https://app.yourdomain.com,https://admin.yourdomain.com,https://yourapp.vercel.app

# -----------------------------------------------------------------------------
# Rate limiting
# -----------------------------------------------------------------------------
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# -----------------------------------------------------------------------------
# Geo / Discovery
# -----------------------------------------------------------------------------
DEFAULT_LOCATION_FUZZ_METERS=300
MAX_DISCOVERY_RADIUS_KM=100
DISCOVERY_CAP_FREE=30
DISCOVERY_CAP_PREMIUM=50

# -----------------------------------------------------------------------------
# Stripe (subscriptions, checkout)
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret

# Deep link for Stripe checkout success/cancel redirects
APP_URL=shhh://

# -----------------------------------------------------------------------------
# Mobile / Expo (client-side; EXPO_PUBLIC_* exposed to app)
# -----------------------------------------------------------------------------
# API base URL. When unset, app uses localhost (web) or 10.0.2.2 (Android emulator).
# EXPO_PUBLIC_API_URL=https://api.yourdomain.com

# OAuth client IDs for mobile (must match backend provider config)
# EXPO_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
# EXPO_PUBLIC_SNAP_CLIENT_ID=your-snap-client-id

# -----------------------------------------------------------------------------
# Admin dashboard (optional)
# -----------------------------------------------------------------------------
# Admin dashboard API base is hardcoded in src/api/client.ts.
# For production, set VITE_API_URL and update admin to use it, or deploy with build-time env.
# VITE_API_URL=https://api.yourdomain.com
